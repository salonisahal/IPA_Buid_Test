default_platform(:ios)

platform :ios do
  desc "Build a signed release IPA using fastlane match"
  lane :build_ios do
    setup_ci if ENV["CI"]

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_KEY_CONTENT"],
      is_key_content_base64: true,
      in_house: false
    )

    match(
      type: "appstore",
      api_key: api_key,
      readonly: true
    )

    increment_build_number(
      xcodeproj: "ios/project.xcodeproj",
      build_number: ENV["BUILD_NUMBER"] || number_of_commits.to_s
    )

    build_app(
      workspace: "ios/project.xcworkspace",
      scheme: "project",
      export_method: "app-store",
      output_directory: "build",
      output_name: "app.ipa",
      export_options: {
        provisioningProfiles: {
          ENV["APP_IDENTIFIER"] || "com.xccelera.project" => ENV["MATCH_PROVISIONING_PROFILE_NAME"]
        }
      }
    )
  end
end
